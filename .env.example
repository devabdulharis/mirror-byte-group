# ======================================================================
# TELEGRAM DOWNLOAD BOT — Contoh file .env
# ======================================================================
# Copy file ini ke .env dan isi nilai-nilainya:
#   cp .env.example .env

# === TELEGRAM (WAJIB) ===
# Dapatkan dari @BotFather di Telegram
BOT_TOKEN=
API_ID=
API_HASH=
# ID Telegram kamu (bisa dapat dari @userinfobot)
OWNER_ID=

# === AI (OpenAI-compatible) like 9router ===
# API key untuk AI assistant (bisa dari OpenAI, Claude API, atau panel custom)
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# === GOOGLE DRIVE (Opsional) ===
# Path ke file credentials.json hasil download dari Google Cloud Console
GDRIVE_CREDENTIALS_JSON=credentials.json
# ID folder Google Drive tujuan upload
GDRIVE_FOLDER_ID=

# === TERABOX (Opsional, untuk download & upload) ===
# Lihat README untuk cara mengambil token
TERABOX_COOKIE=
TERABOX_BDS_TOKEN=
TERABOX_JS_TOKEN=
TERABOX_DEVID=

# === GOFILE (Opsional) ===
# Token dari gofile.io (dapatkan dengan register akun)
GOFILE_TOKEN=

# === SETTINGS ===
# Maks file size untuk upload ke Telegram (dalam MB)
MAX_FILE_SIZE_TG=2000
# Lokasi download
DOWNLOAD_PATH=./downloads
# Database URL
DATABASE_URL=sqlite:///bot.db
# Daftar authorized users (pisah dengan koma, kosongkan = semua user diizinkan)
AUTHORIZED_USERS=
